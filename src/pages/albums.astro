---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
const albums = Object.values(import.meta.glob('./albums/*.astro', { eager: true }));
---

<Layout title="Albums">
	<main>
        <ul>
		{albums.map((post: any) => <li><a href={post.url}>{post.title}</a></li>)}
        </ul>
	</main>
</Layout>

<style/>
